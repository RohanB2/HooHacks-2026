GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT — any random 32+ char string, e.g.: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# URLs
FRONTEND_URL=https://your-vercel-url.vercel.app
BACKEND_URL=https://your-railway-url.railway.app

# PostgreSQL — auto-set by Railway PostgreSQL plugin; set manually for local dev
DATABASE_URL=postgresql://user:password@localhost:5432/wrangler
