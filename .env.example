# ─── Required ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=            # Google AI Studio API key

# ─── Search & scraping (enables web search + dining menu tools) ───────────────
TAVILY_API_KEY=            # Tavily search API key
FIRECRAWL_API_KEY=         # Firecrawl key (fc-... format, NOT fc_dev_...)

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=              # PostgreSQL connection string

# ─── Auth (Google OAuth) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=          # Google Cloud OAuth 2.0 client ID
GOOGLE_CLIENT_SECRET=      # Google Cloud OAuth 2.0 client secret
JWT_SECRET=                # Secret for signing JWTs (change from default in prod)
BACKEND_URL=http://localhost:3000   # Public URL of the backend (used for OAuth callbacks)
FRONTEND_URL=http://localhost:3001  # Public URL of the frontend (used for OAuth redirects)

# ─── Google Calendar ──────────────────────────────────────────────────────────
# No extra keys needed — uses the same GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET.
# Prerequisites:
#   1. Enable "Google Calendar API" in Google Cloud Console
#   2. Add {BACKEND_URL}/auth/google/calendar/callback to Authorized Redirect URIs
#      in your OAuth 2.0 client configuration

# ─── Frontend (Vercel / Next.js) ─────────────────────────────────────────────
# Set in Vercel, not in this file:
# NEXT_PUBLIC_API_URL=     # Railway backend URL (e.g. https://your-app.up.railway.app)
